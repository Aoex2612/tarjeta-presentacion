---
const nombre = 'Alejandro';
const profesion = 'Estudiante de Ingeniería del Software';
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Welcome!</title>
  </head>
  <body>
    <main class="container">
      <div class="tarjeta">
        <h1>Hola, soy {nombre}</h1>
        <p>{profesion}</p>
      </div>

	  	<h2>sudo pacman -S alejandro-web</h2>
    </main>
  </body>
</html>

<style>
  body {
    background-color: #0f172a;
    margin: 0;
    font-family: system-ui, -apple-system, sans-serif;
    color: #f8fafc;
  }
  .container {
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 100vh;
  }
  .tarjeta {
    background-color: #1e293b;
    padding: 3rem;
    border-radius: 12px;
    text-align: center;
    border: 1px solid #334155;
  }
  h1 {
    margin: 0 0 0.5rem 0;
    font-size: 2.5rem;
    color: #60a5fa;
  }
  p {
    margin: 0;
    color: #94a3b8;
    font-size: 1.2rem;
  }

  h2 {
	font-family: 'JetBrains Mono', 'Fira Code', 'Courier New', monospace;
    background-color: #090d16; 
    color: #4ade80; 
    padding: 0.6rem 1rem;
    border-radius: 6px;
    font-size: 1.1rem;
    font-weight: 500;
    display: inline-block;
    margin-top: 1.5rem;
    border: 1px solid #1e293b;
    letter-spacing: 0.05em;
  }
</style>